<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Chi tiết bài viết</title>
<link rel="stylesheet" href="/styles.css">
</head>
<body>
<header>
<h1><%= post.title %></h1>
</header>

<main>
<p><%= post.body %></p>

<a href="/blogposts/<%= post._id %>/edit" class="btn-edit">Chỉnh sửa</a>

<form action="/blogposts/<%= post._id %>/delete" method="POST" class="btn-delete-form" style="display:inline;">
  <button type="submit" class="btn-delete">Xóa</button>
</form>

<a href="/" class="btn-home">Về trang chủ</a>
</main>
</body>
</html>